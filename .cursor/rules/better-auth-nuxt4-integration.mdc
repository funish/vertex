# Better Auth + Nuxt 4 Integration Best Practices

## Overview

Better Auth is a comprehensive TypeScript authentication framework that integrates seamlessly with Nuxt 4. This guide provides best practices for integrating Better Auth with Nuxt 4's new directory structure and features.

## Project Setup

### 1. Installation

```bash
# Install Better Auth core packages
pnpm add better-auth

# Install database driver (choose one)
pnpm add pg  # For PostgreSQL
pnpm add better-sqlite3  # For SQLite
pnpm add mongodb  # For MongoDB

# Install CLI for migrations
pnpm add -D @better-auth/cli
```

### 2. Nuxt 4 Directory Structure

Adapt Better Auth to Nuxt 4's new `app/` directory structure:

```
app/
  utils/
    auth.ts           # Better Auth server config
    auth-client.ts    # Better Auth client config
  middleware/
    auth.global.ts    # Authentication middleware
  composables/
    useAuth.ts        # Authentication composables
  components/
    auth/
      LoginForm.vue
      SignupForm.vue
server/
  api/
    auth/
      [...all].ts     # Better Auth API handler
  middleware/
    cors.ts           # CORS configuration
```

## Server Configuration

### 1. Better Auth Server Setup

Create `app/utils/auth.ts`:

```typescript
import { betterAuth } from "better-auth";
import { admin, organization, twoFactor } from "better-auth/plugins";
import { Pool } from "pg";

export const auth = betterAuth({
  // Database configuration using native PostgreSQL Pool
  database: new Pool({
    connectionString: process.env.DATABASE_URL,
  }),

  // Email & Password authentication
  emailAndPassword: {
    enabled: true,
    requireEmailVerification: true,
    sendResetPassword: async ({ user, url, token }) => {
      // Send password reset email
      await $fetch("/api/v1/email/send-reset", {
        method: "POST",
        body: { email: user.email, url, token },
      });
    },
  },

  // Social providers
  socialProviders: {
    github: {
      clientId: process.env.GITHUB_CLIENT_ID!,
      clientSecret: process.env.GITHUB_CLIENT_SECRET!,
    },
    google: {
      clientId: process.env.GOOGLE_CLIENT_ID!,
      clientSecret: process.env.GOOGLE_CLIENT_SECRET!,
    },
  },

  // Plugins
  plugins: [admin(), organization(), twoFactor()],

  // Advanced configuration
  advanced: {
    useSecureCookies: process.env.NODE_ENV === "production",
    cookiePrefix: "better-auth",
    crossSubDomainCookies: {
      enabled: false,
    },
  },

  // Rate limiting
  rateLimit: {
    enabled: true,
    window: 60, // 1 minute
    max: 100, // 100 requests per minute
    storage: "database",
  },
});
```

### 2. API Route Handler

Create `server/api/v1/[...all].ts`:

```typescript
export default defineEventHandler(async (event) => {
  return auth.handler(toWebRequest(event));
});
```

### 3. CORS Configuration

Create `server/middleware/cors.ts`:

```typescript
import cors from "cors";

export default defineEventHandler((event) => {
  // Skip CORS for non-auth routes
  if (!event.node.req.url?.startsWith("/api/v1/auth")) {
    return;
  }

  return new Promise((resolve) => {
    cors({
      origin:
        process.env.NODE_ENV === "development"
          ? "http://localhost:3000"
          : process.env.NUXT_PUBLIC_SITE_URL,
      credentials: true,
      methods: ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
    })(event.node.req, event.node.res, resolve);
  });
});
```

## Client Configuration

### 1. Better Auth Client Setup

Create `app/utils/auth-client.ts`:

```typescript
import { createAuthClient } from "better-auth/vue";
import {
  adminClient,
  organizationClient,
  twoFactorClient,
} from "better-auth/client/plugins";

export const authClient = createAuthClient({
  baseURL:
    process.env.NODE_ENV === "development"
      ? "http://localhost:3000"
      : process.env.NUXT_PUBLIC_SITE_URL,

  plugins: [adminClient(), organizationClient(), twoFactorClient()],
});

// Export for server-side usage
export { authClient as $auth };
```

### 2. Authentication Composables

Create `app/composables/useAuth.ts`:

```typescript
export const useAuth = () => {
  // Reactive session data
  const { data: session, pending } = authClient.useSession(useFetch);

  // Computed properties
  const user = computed(() => session.value?.user ?? null);
  const isLoggedIn = computed(() => !!session.value?.session);
  const isLoading = computed(() => pending.value);

  // Authentication methods
  const signIn = async (email: string, password: string) => {
    try {
      const result = await authClient.signIn.email({
        email,
        password,
      });

      if (result.error) {
        throw createError({
          statusCode: 401,
          statusMessage: result.error.message,
        });
      }

      await navigateTo("/dashboard");
      return result;
    } catch (error) {
      console.error("Sign in error:", error);
      throw error;
    }
  };

  const signUp = async (email: string, password: string, name: string) => {
    try {
      const result = await authClient.signUp.email({
        email,
        password,
        name,
      });

      if (result.error) {
        throw createError({
          statusCode: 400,
          statusMessage: result.error.message,
        });
      }

      return result;
    } catch (error) {
      console.error("Sign up error:", error);
      throw error;
    }
  };

  const signOut = async () => {
    try {
      await authClient.signOut();
      await navigateTo("/");
    } catch (error) {
      console.error("Sign out error:", error);
      throw error;
    }
  };

  const signInSocial = async (provider: "github" | "google") => {
    try {
      await authClient.signIn.social({
        provider,
        callbackURL: "/dashboard",
      });
    } catch (error) {
      console.error("Social sign in error:", error);
      throw error;
    }
  };

  return {
    // State
    session: readonly(session),
    user,
    isLoggedIn,
    isLoading,

    // Methods
    signIn,
    signUp,
    signOut,
    signInSocial,
  };
};

// Server-side session helper
export const useServerAuth = () => {
  return auth.api.getSession({
    headers: useRequestHeaders(["cookie"]),
  });
};
```

### 3. Global Authentication Middleware

Create `app/middleware/auth.global.ts`:

```typescript
export default defineNuxtRouteMiddleware(async (to, from) => {
  // Skip middleware on server-side
  if (process.server) return;

  // Get session data
  const { data: session } = await authClient.useSession(useFetch);

  // Protected routes
  const protectedRoutes = ["/dashboard", "/profile", "/admin"];
  const isProtectedRoute = protectedRoutes.some((route) =>
    to.path.startsWith(route)
  );

  // Redirect to login if accessing protected route without session
  if (isProtectedRoute && !session.value?.session) {
    return navigateTo("/auth/signin");
  }

  // Redirect away from auth pages if already logged in
  const authRoutes = ["/auth/signin", "/auth/signup"];
  const isAuthRoute = authRoutes.includes(to.path);

  if (isAuthRoute && session.value?.session) {
    return navigateTo("/dashboard");
  }
});
```

