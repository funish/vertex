```

### 2. Dynamic Routes
```vue
<!-- pages/blog/[slug].vue -->
<template>
  <article class="blog-post">
    <header class="blog-post__header">
      <h1>{{ post.title }}</h1>
      <time :datetime="post.publishedAt">
        {{ formatDate(post.publishedAt) }}
      </time>
    </header>
    <div class="blog-post__content" v-html="post.content" />
  </article>
</template>

<script setup lang="ts">
const route = useRoute()
const slug = route.params.slug as string

// Data fetching
const { data: post } = await useLazyFetch(`/api/v1/posts/${slug}`)

if (!post.value) {
  throw createError({
    statusCode: 404,
    statusMessage: 'Post not found'
  })
}

// Dynamic SEO
useSeoMeta({
  title: post.value.title,
  description: post.value.excerpt,
  ogTitle: post.value.title,
  ogDescription: post.value.excerpt
})

// Utility functions
const formatDate = (date: string) => {
  return new Date(date).toLocaleDateString('en-US')
}
</script>
```

## Server-side API Development Patterns

### 1. API Route Structure
```typescript
// server/api/v1/posts/[id].get.ts
export default defineEventHandler(async (event) => {
  const id = getRouterParam(event, 'id')
  
  // Validate parameters
  if (!id || isNaN(Number(id))) {
    throw createError({
      statusCode: 400,
      statusMessage: 'Invalid post ID'
    })
  }
  
  try {
    // Simulate database query
    const post = await getPostById(Number(id))
    
    if (!post) {
      throw createError({
        statusCode: 404,
        statusMessage: 'Post not found'
      })
    }
    
    return post
  } catch (error) {
    throw createError({
      statusCode: 500,
      statusMessage: 'Internal server error'
    })
  }
})
```

### 2. Middleware Development
```typescript
// server/middleware/auth.ts
export default defineEventHandler(async (event) => {
  // Apply authentication only to API routes
  if (!event.node.req.url?.startsWith('/api/v1/')) {
    return
  }
  
  const token = getHeader(event, 'authorization')?.replace('Bearer ', '')
  
  if (!token) {
    throw createError({
      statusCode: 401,
      statusMessage: 'Authorization required'
    })
  }
  
  try {
    const user = await verifyToken(token)
    event.context.user = user
  } catch (error) {
    throw createError({
      statusCode: 401,
      statusMessage: 'Invalid token'
    })
  }
})
```

## Error Handling Patterns

### 1. Global Error Handling
```vue
<!-- error.vue -->
<template>
  <div class="error-page">
    <div class="error-page__content">
      <h1>{{ error.statusCode }}</h1>
      <p>{{ error.statusMessage }}</p>
      <NuxtLink to="/" class="btn btn-primary">
        Back to Home
      </NuxtLink>
    </div>
  </div>
</template>

<script setup lang="ts">
const props = defineProps<{
  error: {
    statusCode: number
    statusMessage: string
  }
}>()

// Set error page title
useSeoMeta({
  title: `${props.error.statusCode} - Page Error`
})
</script>
```

### 2. Async Error Handling
```typescript
// composables/useAsyncError.ts
export const useAsyncError = () => {
  const handleError = (error: any) => {
    if (error.statusCode === 404) {
      throw createError({
        statusCode: 404,
        statusMessage: 'Resource not found'
      })
    }
    
    if (error.statusCode === 401) {
      navigateTo('/login')
      return
    }
    
    // Other errors
    console.error('Unexpected error:', error)
    throw createError({
      statusCode: 500,
      statusMessage: 'Server error'
    })
  }
  
  return {
    handleError
  }
}
```

## Testing Patterns

### 1. Component Testing
```typescript
// tests/components/Button.test.ts
import { describe, it, expect } from 'vitest'
import { mount } from '@vue/test-utils'
import Button from '~/components/Button.vue'

describe('Button', () => {
  it('renders properly', () => {
    const wrapper = mount(Button, {
      props: {
        title: 'Test Button'
      }
    })
    
    expect(wrapper.text()).toContain('Test Button')
  })
  
  it('emits click event', async () => {
    const wrapper = mount(Button)
    
    await wrapper.trigger('click')
    
    expect(wrapper.emitted('click')).toBeTruthy()
  })
})
```

### 2. API Testing
```typescript
// tests/api/v1/posts.test.ts
import { describe, it, expect } from 'vitest'
import { $fetch } from 'ofetch'

describe('/api/v1/posts', () => {
  it('returns posts list', async () => {
    const posts = await $fetch('/api/v1/posts')
    
    expect(Array.isArray(posts)).toBe(true)
    expect(posts.length).toBeGreaterThan(0)
  })
})
```



