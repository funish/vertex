# Nuxt 4 Development Patterns

## Component Development Patterns

### 1. Component Structure
```vue
<template>
  <div class="component-name">
    <!-- Use semantic HTML -->
    <header class="component-name__header">
      <h2 class="component-name__title">{{ title }}</h2>
    </header>
    <main class="component-name__content">
      <slot />
    </main>
  </div>
</template>

<script setup lang="ts">
// Define Props interface
interface Props {
  title: string
  variant?: 'primary' | 'secondary'
  disabled?: boolean
}

// Use withDefaults to set default values
const props = withDefaults(defineProps<Props>(), {
  variant: 'primary',
  disabled: false
})

// Define Emits
const emit = defineEmits<{
  click: [event: MouseEvent]
  change: [value: string]
}>()

// Component state
const isLoading = ref(false)
const internalValue = ref('')

// Computed properties
const computedClass = computed(() => ({
  'component-name--primary': props.variant === 'primary',
  'component-name--secondary': props.variant === 'secondary',
  'component-name--disabled': props.disabled
}))

// Lifecycle hooks
onMounted(() => {
  console.log('Component mounted')
})
</script>

<style scoped>
.component-name {
  @apply block;
  
  &__header {
    @apply mb-4;
  }
  
  &__title {
    @apply text-lg font-semibold;
  }
  
  &__content {
    @apply flex-1;
  }
  
  &--primary {
    @apply bg-blue-500 text-white;
  }
  
  &--secondary {
    @apply bg-gray-500 text-white;
  }
  
  &--disabled {
    @apply opacity-50 pointer-events-none;
  }
}
</style>
```

### 2. Component Naming Conventions
- Use PascalCase: `MyComponent.vue`
- Nested components: `components/base/Button.vue` → `<BaseButton />`
- Client-side components: `Comments.client.vue`
- Server-side components: `Comments.server.vue`

### 3. Component Organization
```
components/
  base/
    Button.vue
    Input.vue
    Modal.vue
  layout/
    Header.vue
    Footer.vue
    Sidebar.vue
  feature/
    UserProfile.vue
    ProductCard.vue
```

## Composables Development Patterns

### 1. Standard Composable Structure
```typescript
// composables/useAuth.ts
export const useAuth = () => {
  // State management
  const user = ref<User | null>(null)
  const isLoading = ref(false)
  
  // Methods
  const login = async (credentials: LoginCredentials) => {
    isLoading.value = true
    try {
      const response = await $fetch('/api/v1/auth/login', {
        method: 'POST',
        body: credentials
      })
      user.value = response.user
      await navigateTo('/dashboard')
    } catch (error) {
      throw createError({
        statusCode: 401,
        statusMessage: 'Invalid credentials'
      })
    } finally {
      isLoading.value = false
    }
  }
  
  const logout = async () => {
    await $fetch('/api/v1/auth/logout', { method: 'POST' })
    user.value = null
    await navigateTo('/login')
  }
  
  // Computed properties
  const isAuthenticated = computed(() => !!user.value)
  
  // Return public API
  return {
    user: readonly(user),
    isLoading: readonly(isLoading),
    isAuthenticated,
    login,
    logout
  }
}
```

### 2. State Management Composable
```typescript
// composables/useState.ts
export const useCounter = () => {
  const count = useState('counter', () => 0)
  
  const increment = () => count.value++
  const decrement = () => count.value--
  const reset = () => count.value = 0
  
  return {
    count,
    increment,
    decrement,
    reset
  }
}
```

### 3. API Request Composable
```typescript
// composables/useApi.ts
export const useApi = <T>(url: string, options?: any) => {
  const { data, pending, error, refresh } = useLazyFetch<T>(url, {
    ...options,
    transform: (data: any) => data,
    onRequest({ request, options }) {
      // Request interceptor
      console.log('Request:', request)
    },
    onResponse({ response }) {
      // Response interceptor
      console.log('Response:', response.status)
    },
    onResponseError({ response }) {
      // Error handling
      console.error('API Error:', response.status)
    }
  })
  
  return {
    data,
    pending,
    error,
    refresh
  }
}
```

## Page Development Patterns

### 1. Page Structure
```vue
<!-- pages/index.vue -->
<template>
  <div class="page-home">
    <AppHeader />
    <main class="page-home__content">
      <section class="hero">
        <h1>{{ title }}</h1>
        <p>{{ description }}</p>
      </section>
      <section class="features">
        <FeatureCard
          v-for="feature in features"
          :key="feature.id"
          :feature="feature"
        />
      </section>
    </main>
    <AppFooter />
  </div>
</template>

<script setup lang="ts">
// Define page metadata
definePageMeta({
  title: 'Home Page',
  description: 'Welcome to our website',
  layout: 'default'
})

// SEO setup
useSeoMeta({
  title: 'Home - My Site',
  ogTitle: 'Home - My Site',
  description: 'Welcome to our amazing website',
  ogDescription: 'Welcome to our amazing website',
  ogImage: '/og-image.jpg'
})

// Data fetching
const { data: features } = await useLazyFetch('/api/v1/features')

// Page state
const title = ref('Welcome to Nuxt 4')
const description = ref('The future of Vue.js development')
</script>

<style scoped>
.page-home {
  @apply min-h-screen;
  
